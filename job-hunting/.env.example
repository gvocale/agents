# Required
GEMINI_API_KEY=...
GMAIL_SENDER_EMAIL=gvocale@gmail.com

# Optional
LOG_LEVEL=INFO

# For containerised deployments (Railway, Fly.io, Render, etc.):
# Base64-encode your credentials.json and token.json and paste the output here.
# The agent will decode these at startup instead of reading files from disk.
#
# Generate with:
#   base64 -i credentials.json | tr -d '\n'
#   base64 -i token.json | tr -d '\n'
#
# GMAIL_CREDENTIALS_JSON=base64-encoded-content
# GMAIL_TOKEN_JSON=base64-encoded-content
